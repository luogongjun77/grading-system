{
  "$schema": "https://railway.app/project-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "name": "grading-system",
      "install": ["pip install -r backend/requirements.txt"],
      "start": "cd backend && python app.py"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
